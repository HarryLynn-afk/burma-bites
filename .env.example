# Burma Bites — Local development configuration
# ⚠️  NEVER commit your actual .env file. It contains secret tokens.

# ── 1. Google Gemini API Key (Required) ──
# Obtain a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── 2. Google GenAI Enterprise Flag (Required) ──
# Set to FALSE to use standard developer tier AI Studio billing / rate limits
GOOGLE_GENAI_USE_ENTERPRISE=FALSE

# ── 3. Telegram Customer Bot Token (Required for Telegram interface) ──
# Token generated by @BotFather for the front-of-house customer order bot
CUSTOMER_BOT_TOKEN=your_customer_bot_token_here

# ── 4. Telegram Kitchen Bot Token (Required for Telegram interface) ──
# Token generated by @BotFather for the kitchen staff operations bot
KITCHEN_BOT_TOKEN=your_kitchen_bot_token_here

# ── 5. Telegram Owner Bot Token (Required for Telegram interface) ──
# Token generated by @BotFather for the business intelligence owner bot
OWNER_BOT_TOKEN=your_owner_bot_token_here

# ── Alternative: Vertex AI Configuration (optional) ──
# If using Vertex AI instead of Google AI Studio, comment out GEMINI_API_KEY
# and uncomment the variables below:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

